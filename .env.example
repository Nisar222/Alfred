# Copy to .env and replace every value marked CHANGE_ME. Never commit .env.
POSTGRES_DB=jamal_dialler
POSTGRES_USER=jamal
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

# The dashboard/API stays private to the VPS by default. A TLS reverse proxy
# (Caddy or Nginx) should be the only public entry point.
API_BIND_ADDRESS=127.0.0.1
API_PORT=8000
CALL_PROVIDER=simulator
MAX_CONCURRENT_CALLS=8
CORS_ORIGINS=http://localhost:8000

# 3CX V20 Call Control (for the safe connection check; never commit a real key).
THREECX_BASE_URL=https://your-pbx.3cx.cloud
THREECX_APP_ID=your-service-principal-id
THREECX_API_KEY=CHANGE_ME_STORE_ONLY_ON_VPS
THREECX_CONTROL_EXTENSION=101
